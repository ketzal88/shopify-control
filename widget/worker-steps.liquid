{%- comment -%}
  worker-steps · "Pasos de uso" (shopify-control). Bloque Custom Liquid en la ficha.
  Lee product.metafields.worker.steps. Sin ítems, no renderiza. Texto server-rendered
  (| escape). Guard: COSMETIC_METAFIELDS.
{%- endcomment -%}
{%- assign st = product.metafields.worker.steps.value -%}
{%- if st and st.items and st.items.size > 0 -%}
<ol id="worker-steps" class="wst">
  {%- for it in st.items -%}
  <li><span class="wst-n">{{ forloop.index }}</span><span class="wst-t">{{ it | escape }}</span></li>
  {%- endfor -%}
</ol>
<style>
  #worker-steps.wst{ font-family:inherit; color:#4B4B4B; margin:18px auto; max-width:460px;
    list-style:none; padding:0; counter-reset:none; }
  #worker-steps li{ display:flex; align-items:flex-start; gap:11px; padding:7px 0; position:relative; }
  #worker-steps li:not(:last-child)::before{ content:""; position:absolute; left:13px; top:30px;
    bottom:-4px; width:2px; background:rgba(75,75,75,.14); }
  #worker-steps .wst-n{ flex:0 0 26px; width:26px; height:26px; border-radius:50%; background:#9CB0B1;
    color:#fff; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; z-index:1; }
  #worker-steps .wst-t{ font-size:13.5px; line-height:1.5; padding-top:3px; }
</style>
{%- endif -%}
