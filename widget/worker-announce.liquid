{%- comment -%}
  worker-announce · "Barra de anuncios" (shopify-control). Bloque Custom Liquid en el
  layout (arriba de todo), es de TODA la tienda: lee shop.metafields.worker.announce.
  Sin texto, no renderiza. El link ya viene validado (https) por el guard.
{%- endcomment -%}
{%- assign an = shop.metafields.worker.announce.value -%}
{%- if an and an.text -%}
{%- if an.link -%}
<a id="worker-announce" class="wan" href="{{ an.link | escape }}">{{ an.text | escape }}</a>
{%- else -%}
<div id="worker-announce" class="wan">{{ an.text | escape }}</div>
{%- endif -%}
<style>
  #worker-announce.wan{ display:block; font-family:inherit; background:#4B4B4B; color:#fff;
    text-align:center; font-size:12.5px; font-weight:600; letter-spacing:.02em; padding:9px 14px;
    text-decoration:none; }
  a#worker-announce.wan:hover{ opacity:.92; }
</style>
{%- endif -%}
