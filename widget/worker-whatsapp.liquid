{%- comment -%}
  ============================================================================
  worker-whatsapp · botón flotante de WhatsApp  (shopify-control · Pack LatAm F3)
  ============================================================================
  Bloque Custom Liquid. Se pega UNA vez en el LAYOUT del tema (theme.liquid,
  antes de </body>) para que aparezca en toda la tienda. NO se edita ningún
  archivo del tema más que ese pegado.

  Lee el ítem `whatsapp` de shop.metafields.worker.trust (es de toda la tienda,
  no por producto). Si no hay ítem whatsapp, no renderiza nada. No captura nada:
  abre wa.me con el mensaje pre-cargado. El teléfono ya viene validado por el
  guard (solo dígitos) y el texto sin `<`/`>`.

  Diseño: docs/superpowers/specs/2026-07-22-pack-latam-vitrina-design.md §6
  ============================================================================
{%- endcomment -%}

{%- assign wa = null -%}
{%- if shop.metafields.worker.trust.value.items -%}
  {%- for it in shop.metafields.worker.trust.value.items -%}
    {%- if it.type == "whatsapp" -%}{%- assign wa = it -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- if wa -%}

<a id="worker-whatsapp" class="ww" target="_blank" rel="noopener noreferrer"
   aria-label="Escribinos por WhatsApp"
   href="https://wa.me/{{ wa.phone }}{% if wa.text %}?text={{ wa.text | url_encode }}{% endif %}">
  <svg viewBox="0 0 32 32" width="30" height="30" fill="currentColor" aria-hidden="true">
    <path d="M16 3C9 3 3.5 8.5 3.5 15.5c0 2.5.7 4.8 1.9 6.8L4 29l6.9-1.8c1.9 1 4.1 1.6 6.4 1.6 6.9 0 12.5-5.6 12.5-12.5S22.9 3 16 3zm0 22.8c-2 0-3.9-.5-5.5-1.5l-.4-.2-4.1 1.1 1.1-4-.3-.4a10 10 0 01-1.6-5.4c0-5.6 4.6-10.2 10.3-10.2 5.6 0 10.2 4.6 10.2 10.2s-4.6 10.4-9.7 10.4zm5.6-7.6c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5l-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.2 3.4 5.3 4.7 2 .8 2.7.9 3.7.8.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.4.2-1.5l-.4-.6z"/>
  </svg>
</a>

<style>
  #worker-whatsapp.ww{
    position:fixed; right:18px; bottom:18px; z-index:998;
    width:54px; height:54px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    background:#25D366; color:#fff; text-decoration:none;
    box-shadow:0 4px 14px rgba(0,0,0,.22); transition:transform .15s ease;
  }
  #worker-whatsapp.ww:hover{ transform:scale(1.06); }
  @media (max-width:480px){
    #worker-whatsapp.ww{ right:14px; bottom:14px; width:50px; height:50px; }
  }
</style>
{%- endif -%}
